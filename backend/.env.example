# ──────────────────────────────────────────────────────────────
#  .env.example  —  Mrohaung Backend Environment Template
#  Copy this file to .env and fill in your actual values.
#  Run: cp .env.example .env
# ──────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# Database (MySQL)
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Admin user IDs (comma-separated UUIDs)
ADMIN_USER_IDS="your-admin-user-uuid-here"

# Base URL
BASE_URL="http://localhost:5000"

# ── Cloudflare R2 Storage ─────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here

R2_BUCKET_NAME="mrohaung-media"
R2_ENDPOINT="https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com"

# ── Email / SMTP ──────────────────────────────────────────────
# In development, emails will default to logging in the console if sending fails.
# In production, recommend using a real SMTP service (Gmail, SendGrid, etc.)

# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_SECURE=false

# Default domain for system emails
EMAIL_DOMAIN="mrohaung.com"

# Redirect for verification links (defaults to http://localhost:3000 in dev)
# FRONTEND_URL="https://mrohaung.com"
